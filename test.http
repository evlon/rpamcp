# RPA MCP Server - HTTP API 测试文件
# 使用 VSCode REST Client / Thunder Client 插件发送请求
# 右键点击请求 -> "Send Request" 或使用快捷键 Ctrl+Alt+R

@host = 192.168.3.7
@http_port = 3001
@mcp_port = 3002
@base_url = http://{{host}}:{{http_port}}
@mcp_url = http://{{host}}:{{mcp_port}}

# =============================================================================
# HTTP API (供影刀 RPA 调用)
# =============================================================================

### 1. 健康检查 - HTTP API
GET {{base_url}}/api/health

### 2. 列出所有已注册技能
GET {{base_url}}/api/skills

### 3. 列出指定应用的技能
GET {{base_url}}/api/skills?appName=元宝应用

### 4. 注册技能
# @name registerSkill
POST {{base_url}}/api/skill/register
Content-Type: application/json

{
  "appName": "query_bot",
  "skillName": "web_search",
  "description": "网页搜索技能"
}

### 5. 注销技能
DELETE {{base_url}}/api/skill/register?appName=query_bot&skillName=web_search

### 6. 创建任务 - 文本查询
# @name createQueryTask
POST {{base_url}}/api/task/create
Content-Type: application/json

{
  "appName": "query_bot",
  "skillName": "text_search",
  "params": {
    "query": "你好"
  }
}

### 7. 创建任务 - 文生图
# @name createImageTask
POST {{base_url}}/api/task/create
Content-Type: application/json

{
  "appName": "元宝应用",
  "skillName": "文生图",
  "params": {
    "prompt": "一个小孩的美丽的笑脸"
  }
}

### 8. 创建任务 - AI 查询
POST {{base_url}}/api/task/create
Content-Type: application/json

{
  "appName": "元宝应用",
  "skillName": "查询",
  "params": {
    "prompt": "移动公司的全称是什么"
  }
}

### 查看结果
0171ec3d-205c-4899-bf11-b913ef681494


### 9. 轮询任务（RPA 调用）- 获取下一个待处理任务
# @name pollTask
GET {{base_url}}/api/task/next?appName=元宝应用

### 10. 轮询任务 - 指定技能
GET {{base_url}}/api/task/next?appName=元宝应用&skillName=文生图

### 11. 查询任务详情（替换 task_id）
@task_id = a11c4f41-22c5-46a7-afcb-5f0aad7ccbaa
GET {{base_url}}/api/task/{{task_id}}

### 12. 完成任务 - 提交结果（替换 task_id）
POST {{base_url}}/api/task/{{task_id}}/complete
Content-Type: application/json

{
  "result": {
    "success": true,
    "data": {
      "answer": "中国移动通信集团有限公司",
      "timestamp": "2026-03-22T10:00:00Z"
    }
  }
}

### 13. 完成任务 - 文生图结果
POST {{base_url}}/api/task/{{task_id}}/complete
Content-Type: application/json

{
  "result": {
    "success": true,
    "image_url": "https://example.com/image/12345.png",
    "prompt": "一个小孩的美丽的笑脸"
  }
}

### 14. 完成任务 - 提交错误
POST {{base_url}}/api/task/{{task_id}}/complete
Content-Type: application/json

{
  "error": "执行失败：API 调用超时"
}

### 15. 列出任务（最近 10 条）
GET {{base_url}}/api/task/next?appName=query_bot&limit=10

# =============================================================================
# MCP Streamable HTTP (供 OpenClaw 调用)
# =============================================================================

### 16. 健康检查 - MCP
GET {{mcp_url}}/health

### 17. MCP 初始化请求
# @name mcpInit
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "initialize",
  "params": {
    "protocolVersion": "2024-11-05",
    "capabilities": {
      "roots": {
        "listChanged": true
      }
    },
    "clientInfo": {
      "name": "test-client",
      "version": "1.0.0"
    }
  },
  "id": 1
}

### 18. MCP 列出工具 (List Tools)
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/list",
  "params": {},
  "id": 2
}

### 19. MCP 调用工具 - register_skill
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "register_skill",
    "arguments": {
      "appName": "test_app",
      "skillName": "hello",
      "description": "Hello World Test"
    }
  },
  "id": 3
}

### 20. MCP 调用工具 - list_skills
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "list_skills",
    "arguments": {}
  },
  "id": 4
}

### 21. MCP 调用工具 - list_skills (带过滤)
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "list_skills",
    "arguments": {
      "appName": "元宝应用"
    }
  },
  "id": 5
}

### 22. MCP 调用工具 - create_task
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "create_task",
    "arguments": {
      "appName": "query_bot",
      "skillName": "text_search",
      "params": {
        "query": "测试查询"
      }
    }
  },
  "id": 6
}

### 23. MCP 调用工具 - get_task_status
# 替换 task_id 为实际值
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "get_task_status",
    "arguments": {
      "taskId": "{{task_id}}"
    }
  },
  "id": 7
}

### 24. MCP 调用工具 - get_task_result
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "get_task_result",
    "arguments": {
      "taskId": "{{task_id}}"
    }
  },
  "id": 8
}

### 25. MCP 调用工具 - list_tasks
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "list_tasks",
    "arguments": {
      "appName": "query_bot",
      "limit": 5
    }
  },
  "id": 9
}

### 26. MCP 调用工具 - unregister_skill
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "tools/call",
  "params": {
    "name": "unregister_skill",
    "arguments": {
      "appName": "test_app",
      "skillName": "hello"
    }
  },
  "id": 10
}

### 27. MCP Ping
POST {{mcp_url}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "method": "ping",
  "params": {},
  "id": 99
}

# =============================================================================
# 使用指南
# =============================================================================
# 
# 1. 修改 @host 变量为你的服务器 IP
#    本地测试：@host = localhost
#    远程测试：@host = 192.168.3.7
#
# 2. 替换变量
#    - {{task_id}}: 替换为实际任务 ID
#    - 请求体中的参数根据实际需求修改
#
# 3. 使用方法
#    - VSCode: 安装 REST Client 插件，点击 "Send Request"
#    - Thunder Client: 直接导入或复制请求
#    - curl: 复制请求到终端
#
# 4. 查看响应
#    - 响应会显示在右侧面板
#    - 可以查看状态码、响应头、响应体
#
# 5. 常用测试流程
#    (1) 健康检查 (#1, #16)
#    (2) 注册技能 (#4)
#    (3) 创建任务 (#6, #7, #8)
#    (4) 轮询任务 (#9)
#    (5) 完成任务 (#12, #13)
#    (6) 查询结果 (#11, #23, #24)
#
# =============================================================================
