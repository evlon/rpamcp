{
  "name": "rpamcp",
  "version": "1.0.0",
  "description": "MCP Server for RPA + 影刀 RPA integration",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MODE=streamable-http MCP_PORT=3002 node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "MODE=streamable-http MCP_PORT=3002 tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk-server-transport-sse": "^0.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
